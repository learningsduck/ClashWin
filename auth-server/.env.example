# 服务端口
PORT=3001

# JWT 密钥（务必改成随机长字符串，生产环境用环境变量注入）
JWT_SECRET=your-super-secret-key-change-in-production

# JWT 过期时间（如 7d、24h）
JWT_EXPIRES_IN=7d

# 短信验证码有效期（秒）
SMS_CODE_EXPIRE_SECONDS=300

# 同一手机号发送验证码间隔（秒）— 与全局频控一致建议 30
SMS_SEND_INTERVAL_SECONDS=30

# 邮箱验证码有效期（秒）
EMAIL_CODE_EXPIRE_SECONDS=900

# 验证码发送频控（短信+邮箱共用）
VERIFICATION_SEND_INTERVAL_SECONDS=30
VERIFICATION_HOURLY_LIMIT=10
VERIFICATION_DAILY_LIMIT=20

# 管理员初始化密钥（首次创建管理员账户时需要）
ADMIN_INIT_SECRET=clash-verge-admin-init-2024

# 数据库路径
DB_PATH=./data/auth.db

# ========== 短信服务 ==========
SMS_PROVIDER=mock

# ========== 邮件服务 ==========
# mock: 验证码写入 data/last-email-code.txt 并打印日志
# smtp: 需自行在 services/email.ts 接入 nodemailer
EMAIL_PROVIDER=mock
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# 阿里云短信（可选）
# ALIYUN_ACCESS_KEY_ID=
# ALIYUN_ACCESS_KEY_SECRET=
# ALIYUN_SMS_SIGN_NAME=
# ALIYUN_SMS_TEMPLATE_CODE=
